{
  "name": "cpcash-rn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer react-native run-ios",
    "postinstall": "node ./scripts/fix-react-native-svg-yoga-compat.mjs",
    "prepare": "sh ./scripts/setup-git-hooks.sh",
    "pods:install": "cd ios && DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer pod install --repo-update",
    "pods:install:mirror": "cd ios && DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer COCOAPODS_SOURCE=https://mirrors.tuna.tsinghua.edu.cn/git/CocoaPods/Specs.git pod install --repo-update",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --runInBand",
    "test:unit:coverage": "jest --runInBand --coverage",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run check:wp00 && npm run check:repo",
    "check:wp00": "node ./scripts/verify-wp00.mjs",
    "check:repo": "node ./scripts/verify-repo-standards.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-documents/picker": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.2.0",
    "@shopify/react-native-skia": "^2.5.1",
    "@tanstack/react-query": "^5.90.14",
    "axios": "^1.8.3",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "ethereum-cryptography": "^3.2.0",
    "ethers": "^6.16.0",
    "expo": "~54.0.0",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-media-library": "~18.2.1",
    "i18next": "^24.2.3",
    "jsencrypt": "^3.5.4",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^15.2.0",
    "react-native": "^0.81.4",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-mmkv": "^3.0.2",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "^0.7.4",
    "react-native-zoom-toolkit": "^5.0.1",
    "react-test-renderer": "^19.1.0",
    "reconnecting-websocket": "^4.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@react-native-community/cli": "^20.1.2",
    "@react-native/babel-preset": "^0.81.4",
    "@react-native/metro-config": "^0.81.4",
    "@react-native/typescript-config": "^0.81.4",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
